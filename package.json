{
  "name": "vel-infotech-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "postbuild": "react-snap",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "reactSnap": {
    "source": "dist",
    "destination": "dist",
    "include": [
      "/",
      "/about",
      "/all-courses",
      "/careers",
      "/blog",
      "/internship",
      "/interview-questions",
      "/tutorials",
      "/sample-resume",
      "/placed-students",
      "/all-courses/java-full-stack-developer-course",
      "/all-courses/python-full-stack-developer-course",
      "/all-courses/full-stack-development-course",
      "/all-courses/data-science-training-program",
      "/all-courses/data-science-and-ai-program",
      "/all-courses/business-analytics-course",
      "/all-courses/business-analyst-program",
      "/all-courses/big-data-developer-program",
      "/all-courses/sql-developer-course",
      "/all-courses/pl-sql-developer-course",
      "/all-courses/software-testing-program",
      "/all-courses/selenium-testing-program",
      "/all-courses/etl-testing-program",
      "/all-courses/aws-training-program",
      "/all-courses/devops-training-program",
      "/all-courses/servicenow-training-program",
      "/all-courses/salesforce-training-program",
      "/all-courses/sap-training-program",
      "/all-courses/cyber-security-program",
      "/all-courses/hardware-and-networking-program",
      "/all-courses/product-management-program",
      "/all-courses/scrum-master-program",
      "/all-courses/rpa-robotic-process-automation-course",
      "/all-courses/digital-marketing-program",
      "/all-courses/soft-skills-training",
      "/all-courses/production-support-program",
      "/client",
      "/contact-us"
    ],
    "minifyHtml": {
      "collapseWhitespace": false,
      "removeComments": false
    },
    "puppeteerArgs": ["--no-sandbox", "--disable-setuid-sandbox"],
    "headless": true,
    "concurrency": 1,
    "timeout": 10000,
    "crawl": false,
    "skipThirdPartyRequests": true
  },
  "dependencies": {
    "@googlemaps/js-api-loader": "^2.0.1",
    "@heroicons/react": "^2.2.0",
    "@material-tailwind/react": "^2.1.10",
    "@reduxjs/toolkit": "^2.8.2",
    "@tailwindcss/vite": "^4.1.11",
    "aos": "^2.3.4",
    "axios": "^1.11.0",
    "framer-motion": "^12.23.24",
    "lucide-react": "^0.534.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^2.0.5",
    "react-icons": "^5.5.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.7.1",
    "react-toastify": "^9.1.3",
    "recharts": "^3.2.1",
    "swiper": "^11.2.10",
    "tailwindcss": "^4.1.11",
    "tailwindcss-clip-path": "^1.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "baseline-browser-mapping": "^2.9.19",
    "eslint": "^9.30.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "react-snap": "^1.23.0",
    "vite": "^7.0.4"
  }
}
